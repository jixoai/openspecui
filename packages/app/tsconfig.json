{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@openspecui/core": ["../core/src/index.ts"],
      "@openspecui/core/hosted-app": ["../core/src/hosted-app.ts"],
      "@openspecui/web-src/*": ["../web/src/*"]
