{
  "name": "ctranslate2",
  "version": "0.1.0",
  "description": "Native Node.js bindings for CTranslate2",
  "type": "commonjs",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "Cargo.toml",
    "build.rs",
    "src",
    "ct2.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --package=@napi-rs/cli dlx napi build --platform --release",
    "dev": "pnpm --package=@napi-rs/cli dlx napi build --platform",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "// binary-note": "Keep napi.binaryName fixed to ct2 so the generated loader and published native artifacts stay on the ct2.* surface instead of leaking the default index.* names.",
  "// publish-note": "This package only publishes the loader plus generated ct2.* runtime files. Stale local index.* artifacts must never be matched by the tarball file list.",
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jixoai/openspecui"
  },
  "license": "MIT",
  "keywords": [
    "ctranslate2",
    "translation",
    "nmt",
    "napi",
    "node-addon"
  ],
  "napi": {
    "binaryName": "ct2",
    "packageName": "ctranslate2"
  }
}
